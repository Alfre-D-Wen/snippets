    "cocotb-test_template": {
        "prefix": "dut_test",
        "body": [
            "import cocotb",
            "import logging",
            "from cocotb.triggers import Timer, RisingEdge, with_timeout",
            "from cocotb.clock import Clock",
            "from cocotb.regression import TestFactory",
            "",
            "from cocotb_isp.video_trans import VideoTrans",
            "from cocotb_isp.video_agent import VideoAxisAgent",
            "from cocotb_isp.video_scb import VideoAxisScb",
            "",
            "##############################",
            "## cocotb test",
            "##############################",
            "async def run_test(dut, hsize, vsize, frame_num, test_mode, prob):",
            "    \"\"\"generate main clocks\"\"\"",
            "    cocotb.start_soon(Clock(dut.clk_in, 5, units=\"ns\").start())",
            "",
            "    \"\"\"dut interface\"\"\"",
            "",
            "    \"\"\"log level set\"\"\"",
            "    logging.getLogger().setLevel(logging.INFO)",
            "",
            "    \"\"\"instance\"\"\"",
            "    video_trans = VideoTrans(",
            "        hsize,",
            "        vsize,",
            "        frame_num,",
            "        \"32b\",",
            "        test_mode,",
            "    )",
            "",
            "    video_agent_i = VideoAxisAgent(",
            "        dut,",
            "        is_active=True,",
            "        video_trans=video_trans,",
            "        mon_data_len=hsize * vsize * frame_num,",
            "    )",
            "",
            "    video_agent_o = VideoAxisAgent(",
            "        dut,",
            "        is_active=False,",
            "        video_trans=video_trans,",
            "        mon_data_len=hsize * vsize * frame_num,",
            "    )",
            "",
            "    video_scb = VideoAxisScb(",
            "        \"OUTPUT\",",
            "        video_agent_o.mon,",
            "        video_agent_i.mon,",
            "        32,",
            "        32,",
            "        hsize,",
            "        vsize",
            "    )",
            "",
            "    \"\"\"main tasks\"\"\"   ",
            "    cocotb_run(",
            "        rstn(dut),",
            "        video_agent_i.drv.drv(prob),",
            "        video_agent_i.mon.mon(),",
            "",
            "        video_agent_o.mon.mon(),",
            "        video_agent_o.sink.backpressure(prob),",
            "",
            "        video_scb.check(),",
            "    )",
            "",
            "    await with_timeout(video_agent_o.mon.wait_done(), 100, \"us\")",
            "",
            "async def rstn(dut):",
            "    dut.rst_n_in.value = 0",
            "    await Timer(20, \"ns\")",
            "    await RisingEdge(dut.clk_in)",
            "    dut.rst_n_in.value = 1",
            "",
            "def cocotb_run(*coros):",
            "    for coro in coros:",
            "        cocotb.start_soon(coro)  ",
            "",
            "##############################",
            "## Test Factory",
            "##############################",
            "factory = TestFactory(run_test)",
            "",
            "factory.add_option(\"test_mode\", [])",
            "factory.add_option(\"hsize\", [])",
            "factory.add_option(\"vsize\", [])",
            "factory.add_option(\"frame_num\", [])",
            "factory.add_option(\"prob\", [])",
            "",
            "factory.generate_tests()"
        ],
        "description": "cocotb-test_template"
    },
}